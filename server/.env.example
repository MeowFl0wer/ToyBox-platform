# 复制为 server/.env 并按需修改（.env 已被 gitignore）
# 所有变量前缀 TOYBOX_

# 生产务必改成强随机值（开发态不填会自动持久化随机密钥到 data/）
# TOYBOX_SECRET_KEY=change-me
# TOYBOX_MODULE_SIGN_KEY=change-me

# 邮箱验证码：开发模式直接返回验证码并打印日志（不真正发信）；上线时设为 false
TOYBOX_DEV_MODE=true

# 邮件服务：Resend（上线时填写；dev_mode=false 且填了 key 才会真正发信）
# TOYBOX_RESEND_API_KEY=re_xxxxxxxx
# TOYBOX_MAIL_FROM=ToyBox <noreply@your-domain.com>   # 需在 Resend 验证过的发件域名

# 默认管理员（首次启动创建，建议改掉）
TOYBOX_ADMIN_USERNAME=admin
TOYBOX_ADMIN_EMAIL=admin@toybox.local
TOYBOX_ADMIN_PASSWORD=Admin@12345

# 数据库（默认 SQLite；切 Postgres 示例见下）
# TOYBOX_DB_URL=postgresql+psycopg://user:pass@localhost:5432/main_db
