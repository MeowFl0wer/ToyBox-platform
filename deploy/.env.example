# 生产部署环境变量：复制为 deploy/.env 并填好（.env 已被 gitignore）

# --- 数据库 ---
POSTGRES_PASSWORD=change-this-to-a-strong-password

# --- 安全密钥（务必改成强随机值：openssl rand -base64 48）---
TOYBOX_SECRET_KEY=change-me-jwt-secret
TOYBOX_MODULE_SIGN_KEY=change-me-module-sign-key   # 主站与模块共享，用于签名用户上下文

# --- 初始管理员（首次启动创建，登录后请尽快改密码）---
TOYBOX_ADMIN_USERNAME=admin
TOYBOX_ADMIN_EMAIL=you@your-domain.com
TOYBOX_ADMIN_PASSWORD=change-this-admin-password

# --- 邮件（Resend）：上线发真实验证码 ---
TOYBOX_DEV_MODE=false
TOYBOX_RESEND_API_KEY=re_xxxxxxxx
TOYBOX_MAIL_FROM=ToyBox <noreply@your-domain.com>

# --- 跨域来源（前端域名，JSON 数组）---
TOYBOX_CORS_ORIGINS=["https://your-domain.com"]

# 经 Nginx 反代取真实客户端 IP（compose 已为 backend 设为 true；务必确保 backend 不直接暴露公网）
# TOYBOX_TRUST_PROXY=true
# 模块来源白名单（只允许安装这些 GitHub owner 的仓库，建议生产设置；JSON 数组）
# TOYBOX_MODULE_SOURCE_ALLOWLIST=["MeowFl0wer"]
